        "jsCode": "const _b = $input.first().json.body;\nconst d = typeof _b === 'string' ? JSON.parse(_b) : _b;\nif (d.event !== 'ticket_created') return [];\n\nconst GROUP_ID = '120363425236675583-group';\nconst t = d.ticket;\nconst devTag = t.is_dev ? '\\n🛠️ *Tipo:* Demandas Tech' : '';\nconst desc = t.description ? `\\n📝 *Descrição:* ${t.description}` : '';\n\nconst message =\n  `🚨 *Novo Ticket — Suporte MyBroker* 🚨\\n\\n` +\n  `🕵🏻‍♂️ *Prioridade:* ${t.priority}\\n` +\n  `🏢 *Broker:* ${t.broker}\\n` +\n  `📋 *Título:* ${t.title}` +\n  desc +\n  `\\n👤 *Aberto por:* ${t.created_by}` +\n  devTag +\n  `\\n🕐 ${new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' })}`;\n\nreturn [{ json: { phone: GROUP_ID, message } }];"
