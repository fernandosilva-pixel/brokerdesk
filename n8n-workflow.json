    {
      "id": "code-routine-dispatch",
      "name": "Formatar Rotina do Dia",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        800,
        1260
      ],
      "parameters": {
        "jsCode": "const GROUP_ID = '120363425236675583-group';\n\nconst tasks = $input.all().map(i => i.json);\nif (tasks.length === 0) return [];\n\nconst manha = tasks.filter(t => t.category === 'manha').sort((a, b) => (a.time || '').localeCompare(b.time || ''));\nconst tarde = tasks.filter(t => t.category === 'tarde').sort((a, b) => (a.time || '').localeCompare(b.time || ''));\nconst extra = tasks.filter(t => t.category !== 'manha' && t.category !== 'tarde');\n\nconst fmt = items => items.map(t => `  ☐ ${t.time ? t.time + ' — ' : ''}${t.title}`).join('\\n');\n\nconst sections = [\n  manha.length > 0 ? `🌅 *Manhã*\\n${fmt(manha)}` : '',\n  tarde.length > 0 ? `🌇 *Tarde*\\n${fmt(tarde)}` : '',\n  extra.length > 0 ? `📌 *Extra*\\n${fmt(extra)}` : '',\n].filter(s => s).join('\\n\\n');\n\nconst today = new Date().toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long', timeZone: 'America/Sao_Paulo' });\n\nconst message =\n  `📋 *Suporte MyBroker — Rotina do Dia*\\n\\n` +\n  `📅 ${today}\\n\\n` +\n  sections +\n  `\\n\\n💪 Bom trabalho, equipe!`;\n\nreturn [{ json: { phone: GROUP_ID, message } }];"
      }
    },
