    {
      "id": "code-routine-reminder",
      "name": "Verificar Pendências — Formatar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        1080,
        1460
      ],
      "parameters": {
        "jsCode": "const OPERATORS = [\n  { email: 'proveta24k@gmail.com', phone: '573016195072', firstName: 'Renan' },\n  { email: 'felipe.jose@asap.codes', phone: '573158363095', firstName: 'Felipe' },\n];\n\nconst morningTasks = $('Buscar Tarefas Manhã — Supabase').all().map(i => i.json);\nconst completions = $input.all().map(i => i.json);\n\nif (morningTasks.length === 0) return [];\n\nconst results = [];\n\nfor (const op of OPERATORS) {\n  const opCompletedIds = new Set(\n    completions\n      .filter(c => c.completed_by === op.email)\n      .map(c => c.task_id)\n      .filter(Boolean)\n  );\n  const pending = morningTasks.filter(t => !opCompletedIds.has(t.id));\n  if (pending.length === 0) continue;\n\n  const pendingList = pending.map(t => `  • ${t.time ? t.time + ' — ' : ''}${t.title}`).join('\\n');\n\n  const message =\n    `⏰ *Suporte MyBroker — Lembrete de Rotina*\\n\\n` +\n    `Ei, ${op.firstName}! São 10h da manhã e você ainda tem ${pending.length} tarefa${pending.length > 1 ? 's' : ''} da manhã pendente${pending.length > 1 ? 's' : ''}:\\n\\n` +\n    pendingList +\n    `\\n\\nNão deixa pra última hora — a rotina em dia é o que mantém o time operando no máximo! 💪\\n📱 Acesse o BrokerDesk e marque conforme for concluindo.`;\n\n  results.push({ json: { phone: '120363425236675583-group', message } });\n}\n\nreturn results;"
      }
    },
