    {
      "id": "code-weekly-dept",
      "name": "Formatar Relatório Semanal",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        1660
      ],
      "parameters": {
        "jsCode": "\nconst ADMIN_PHONES = ['573126402098', '12362321766'];\nconst tickets = .all().map(i => i.json);\n\nif (tickets.length === 0) {\n  return [{ json: { phone: ADMIN_PHONE, message: '📊 *Relatório Semanal — Suporte MyBroker*\\n\\nNenhum ticket criado na última semana.' } }];\n}\n\nconst depts = {};\nfor (const t of tickets) {\n  const d = t.department || 'Outros';\n  if (!depts[d]) depts[d] = { total: 0, resolvidos: 0, pendentes: 0 };\n  depts[d].total++;\n  if (t.status === 'Resolvido' || t.status === 'Fechado') depts[d].resolvidos++;\n  else depts[d].pendentes++;\n}\n\nconst sorted = Object.entries(depts).sort((a, b) => b[1].total - a[1].total);\nconst lines = sorted.map(([dept, s], i) => {\n  const medal = i === 0 ? '🔴' : i === 1 ? '🟠' : i === 2 ? '🟡' : '⚪';\n  return ;\n}).join('\\n');\n\nconst top = sorted[0][0];\nconst now = new Date().toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo', weekday: 'long', day: 'numeric', month: 'long' });\n\nconst message =\n   +\n   +\n   +\n   +\n  ;\n\nreturn ADMIN_PHONES.map(phone => ({ json: { phone, message } }));\n"
      }
    },
