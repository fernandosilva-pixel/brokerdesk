    {
      "id": "code-daily-summary",
      "name": "Formatar Resumo Diário",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        800,
        1060
      ],
      "parameters": {
        "jsCode": "const ADMIN_PHONES = ['573126402098', '12362321766'];\n\nconst tickets = $input.all().map(i => i.json);\n\nconst now = new Date();\nconst brazilDate = now.toLocaleDateString('en-CA', { timeZone: 'America/Sao_Paulo' });\nconst todayStartUTC = new Date(brazilDate + 'T03:00:00Z');\n\nconst resolvedToday = tickets.filter(t => {\n  if (t.status !== 'Resolvido') return false;\n  const updated = new Date(t.updated_at);\n  return updated >= todayStartUTC;\n});\n\nconst pending = tickets.filter(t => t.status === 'Pendente');\nconst inProgress = tickets.filter(t => t.status === 'Em Andamento');\n\nconst byAssignee = {};\nresolvedToday.forEach(t => {\n  const name = (t.assigned_to || 'Sem atribuição').split('@')[0];\n  byAssignee[name] = (byAssignee[name] || 0) + 1;\n});\n\nconst sorted = Object.entries(byAssignee).sort((a, b) => b[1] - a[1]);\nconst topResolver = sorted.length > 0\n  ? `🏆 *Destaque do dia:* ${sorted[0][0]} (${sorted[0][1]} ticket${sorted[0][1] > 1 ? 's' : ''})`\n  : '⚠️ Nenhum ticket resolvido hoje';\n\nconst resolvedLines = sorted.length > 0\n  ? sorted.map(([name, count]) => `  • ${name}: ${count} ticket${count > 1 ? 's' : ''}`).join('\\n')\n  : '  Nenhum';\n\nconst pendingBrokers = [...new Set(pending.map(t => t.broker_nome || t.broker))];\nconst brokerList = pendingBrokers.length > 0\n  ? pendingBrokers.map(b => `  • ${b}`).join('\\n')\n  : '  ✅ Nenhuma pendência!';\n\nconst today = now.toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long', timeZone: 'America/Sao_Paulo' });\n\nconst message =\n  `📊 *Suporte MyBroker — Fechamento do Dia*\\n\\n` +\n  `📅 ${today}\\n\\n` +\n  `✅ *Resolvidos hoje:* ${resolvedToday.length}\\n${resolvedLines}\\n\\n` +\n  `${topResolver}\\n\\n` +\n  `⏳ *Ainda pendentes:* ${pending.length}\\n` +\n  `▶️ *Em Andamento:* ${inProgress.length}\\n\\n` +\n  `🔴 *Brokers com pendências:*\\n${brokerList}`;\n\nreturn ADMIN_PHONES.map(phone => ({ json: { phone, message } }));"
      }
    },
