      "id": "code-overdue",
      "name": "Tickets Atrasados — Formatar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        520,
        840
      ],
      "parameters": {
        "jsCode": "const _b = $input.first().json.body;\nconst d = typeof _b === 'string' ? JSON.parse(_b) : _b;\nif (d.event !== 'overdue_check' || !d.tickets || d.tickets.length === 0) return [];\n\nconst GROUP_ID = '120363425236675583-group';\n\nconst lines = d.tickets.map(t =>\n  `• *${t.broker}* — ${t.titulo}\\n  📅 Criado: ${new Date(t.data_criacao).toLocaleDateString('pt-BR')} (${t.dias_em_aberto} dia${t.dias_em_aberto > 1 ? 's' : ''} em aberto)`\n).join('\\n\\n');\n\nconst message =\n  `🚨 *Suporte MyBroker — Demandas Atrasadas*\\n\\n` +\n  `${d.tickets.length} ticket${d.tickets.length > 1 ? 's' : ''} pendente${d.tickets.length > 1 ? 's' : ''} há mais de 3 dias:\\n\\n` +\n  lines +\n  `\\n\\n⚠️ Ação necessária!\\n🕐 ${new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' })}`;\n\nreturn [{ json: { phone: GROUP_ID, message } }];"
