      "name": "Jira — Formatar Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [520, 1900],
      "parameters": {
        "jsCode": "const _b = $input.first().json.body;\nconst d = typeof _b === 'string' ? JSON.parse(_b) : _b;\n\nconst email = d.email || 'sem-email@brokerdesk.com';\nconst title = d.title || 'Novo Bug';\nconst description = d.description || '';\n\n// Substitua pelo base64 de: email_atlassian:api_token\nconst auth = 'Basic ' + Buffer.from($env.JIRA_EMAIL + ':' + $env.JIRA_TOKEN).toString('base64');\n\nconst payload = {\n  fields: {\n    project: { key: 'MMT2' },\n    issuetype: { name: 'Bug' },\n    summary: title,\n    description: {\n      version: 1,\n      type: 'doc',\n      content: [\n        {\n          type: 'paragraph',\n          content: [{ type: 'text', text: 'Reportado por: ' + email, marks: [{ type: 'strong' }] }]\n        },\n        {\n          type: 'paragraph',\n          content: [{ type: 'text', text: description }]\n        }\n      ]\n    }\n  }\n};\n\nreturn [{ json: { auth, payload } }];"
      }
    },
