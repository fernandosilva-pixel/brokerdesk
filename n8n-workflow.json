{
  "name": "BrokerDesk — WhatsApp Alerts via Z-API",
  "nodes": [
    {
      "id": "wh-trigger",
      "name": "Webhook BrokerDesk",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 440],
      "parameters": {
        "httpMethod": "POST",
        "path": "brokerdesk",
        "responseMode": "onReceived",
        "options": {}
      }
    },
    {
      "id": "sw-router",
      "name": "Roteador de Eventos",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [480, 440],
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.body.event }}",
        "rules": {
          "rules": [
            { "value2": "ticket_created" },
            { "value2": "ticket_resolved" },
            { "value2": "routine_task_completed" },
            { "value2": "admin_notification" },
            { "value2": "overdue_check" }
          ]
        },
        "fallbackOutput": "none"
      }
    },

    {
      "id": "code-ticket-created",
      "name": "Novo Ticket — Formatar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [720, 200],
      "parameters": {
        "jsCode": "const ADMIN_PHONE = '5512991001914';\n\nconst d = $input.first().json.body;\nconst t = d.ticket;\nconst pEmoji = { Urgente: '🚨', Alta: '⚠️', Média: '📋', Baixa: '📝' }[t.priority] || '📋';\nconst devTag = t.is_dev ? '\\n🛠️ *Tipo:* Demandas Tech' : '';\n\nconst message =\n  `🎫 *Novo Ticket — BrokerDesk*\\n\\n` +\n  `${pEmoji} *Prioridade:* ${t.priority}\\n` +\n  `🏢 *Broker:* ${t.broker}\\n` +\n  `📋 *Título:* ${t.title}\\n` +\n  `👤 *Aberto por:* ${t.created_by}` +\n  devTag +\n  `\\n\\n🕐 ${new Date().toLocaleString('pt-BR')}`;\n\nreturn [{ json: { phone: ADMIN_PHONE, message } }];"
      }
    },
    {
      "id": "http-ticket-created",
      "name": "Novo Ticket — Enviar WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [960, 200],
      "parameters": {
        "method": "POST",
        "url": "https://api.z-api.io/instances/3F1E76CBFC5FE12CD723BA4D31290A14/token/AD90D2009568787D0FE65CED/send-text",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "phone", "value": "={{ $json.phone }}" },
            { "name": "message", "value": "={{ $json.message }}" }
          ]
        },
        "options": {}
      }
    },

    {
      "id": "code-ticket-resolved",
      "name": "Ticket Resolvido — Formatar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [720, 360],
      "parameters": {
        "jsCode": "const ADMIN_PHONE = '5512991001914';\n\nconst d = $input.first().json.body;\nconst t = d.ticket;\n\nconst message =\n  `✅ *Ticket Resolvido — BrokerDesk*\\n\\n` +\n  `🏢 *Broker:* ${t.broker}\\n` +\n  `📋 *Título:* ${t.title}\\n` +\n  `👤 *Resolvido por:* ${t.resolved_by || 'Operador'}\\n\\n` +\n  `🕐 ${new Date().toLocaleString('pt-BR')}`;\n\nreturn [{ json: { phone: ADMIN_PHONE, message } }];"
      }
    },
    {
      "id": "http-ticket-resolved",
      "name": "Ticket Resolvido — Enviar WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [960, 360],
      "parameters": {
        "method": "POST",
        "url": "https://api.z-api.io/instances/3F1E76CBFC5FE12CD723BA4D31290A14/token/AD90D2009568787D0FE65CED/send-text",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "phone", "value": "={{ $json.phone }}" },
            { "name": "message", "value": "={{ $json.message }}" }
          ]
        },
        "options": {}
      }
    },

    {
      "id": "code-routine-completed",
      "name": "Tarefa Concluída — Formatar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [720, 520],
      "parameters": {
        "jsCode": "const ADMIN_PHONE = '5512991001914';\n\nconst d = $input.first().json.body;\nconst task = d.task;\nconst cat = { manha: '🌅 Manhã', tarde: '🌇 Tarde', custom: '📌 Extra' }[task.category] || task.category;\n\nconst message =\n  `☑️ *Tarefa de Rotina Concluída — BrokerDesk*\\n\\n` +\n  `📋 *Tarefa:* ${task.title}\\n` +\n  `🗂️ *Período:* ${cat}\\n` +\n  `👤 *Operador:* ${task.completed_by || 'Operador'}\\n\\n` +\n  `🕐 ${new Date().toLocaleString('pt-BR')}`;\n\nreturn [{ json: { phone: ADMIN_PHONE, message } }];"
      }
    },
    {
      "id": "http-routine-completed",
      "name": "Tarefa Concluída — Enviar WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
