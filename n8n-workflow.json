    {
      "id": "code-overdue",
      "name": "Tickets Atrasados — Formatar e Dividir",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [720, 840],
      "parameters": {
        "jsCode": "const OPERATOR_PHONES = [\n  '5512991001914', // Fernando (Admin)\n  '5512981963736', // Renan\n  '5512982871400', // Felipe\n  '573126402098', // Fernando\n];\n\nconst d = $input.first().json.body;\nconst tickets = d.tickets || [];\n\nif (tickets.length === 0) return [];\n\nconst lines = tickets.map(t =>\n  `• *${t.broker}* — ${t.titulo}\\n  📅 Criado: ${new Date(t.data_criacao).toLocaleDateString('pt-BR')} (${t.dias_em_aberto} dia${t.dias_em_aberto > 1 ? 's' : ''} em aberto)`\n).join('\\n\\n');\n\nconst message =\n  `🚨 *BrokerDesk — Demandas Atrasadas*\\n\\n` +\n  `${tickets.length} ticket${tickets.length > 1 ? 's' : ''} pendente${tickets.length > 1 ? 's' : ''} há mais de 3 dias:\\n\\n` +\n  lines +\n  `\\n\\n⚠️ Ação necessária!\\n🕐 ${new Date().toLocaleString('pt-BR')}`;\n\nreturn OPERATOR_PHONES.map(phone => ({ json: { phone, message } }));"
      }
    },
