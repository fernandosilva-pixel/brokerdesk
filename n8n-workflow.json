    {
      "id": "code-daily-summary",
      "name": "Formatar Resumo Diário",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [720, 980],
      "parameters": {
        "jsCode": "const OPERATOR_PHONES = [\n  '5512991001914', // Fernando (Admin)\n  '5512981963736', // Renan\n  '5512982871400', // Felipe\n  '573126402098', // Fernando\n];\n\nconst tickets = $input.all().map(i => i.json);\nconst pending = tickets.filter(t => t.status === 'Pendente');\nconst inProgress = tickets.filter(t => t.status === 'Em Andamento');\nconst urgent = tickets.filter(t => t.priority === 'Urgente');\n\nconst uniqueBrokers = [...new Set(pending.map(t => t.broker_nome || t.broker))];\nconst brokerList = uniqueBrokers.length > 0\n  ? uniqueBrokers.map(b => `• ${b}`).join('\\n')\n  : '✅ Nenhuma pendência!';\n\nconst today = new Date().toLocaleDateString('pt-BR', {\n  weekday: 'long', day: 'numeric', month: 'long'\n});\n\nconst message =\n  `📋 *BrokerDesk — Rotina do Dia*\\n\\n` +\n  `📅 ${today}\\n\\n` +\n  `⏳ *Pendentes:* ${pending.length}\\n` +\n  `▶️ *Em Andamento:* ${inProgress.length}\\n` +\n  `🚨 *Urgentes:* ${urgent.length}\\n\\n` +\n  `🔴 *Brokers com pendências:*\\n${brokerList}\\n\\n` +\n  `Bom trabalho, equipe! 💪`;\n\nreturn OPERATOR_PHONES.map(phone => ({ json: { phone, message } }));"
      }
    },
