    {
      "id": "code-admin-notif",
      "name": "Notificação Admin — Formatar e Dividir",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [720, 680],
      "parameters": {
        "jsCode": "const OPERATOR_PHONES = [\n  '5512991001914', // Fernando (Admin)\n  '5512981963736', // Renan\n  '5512982871400', // Felipe\n  '573126402098', // Fernando\n];\n\nconst d = $input.first().json.body;\nconst notif = d.notification;\nconst emojis = { info: 'ℹ️', success: '✅', warning: '⚠️', error: '🚨' };\nconst emoji = emojis[notif.type] || 'ℹ️';\n\nconst message =\n  `${emoji} *BrokerDesk — ${notif.title}*\\n\\n` +\n  `${notif.message}\\n\\n` +\n  `🕐 ${new Date().toLocaleString('pt-BR')}`;\n\nreturn OPERATOR_PHONES.map(phone => ({ json: { phone, message } }));"
      }
    },
    {
      "id": "http-admin-notif",
      "name": "Notificação Admin — Enviar WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [960, 680],
      "parameters": {
        "method": "POST",
        "url": "https://api.z-api.io/instances/3F1E76CBFC5FE12CD723BA4D31290A14/token/AD90D2009568787D0FE65CED/send-text",
        "sendBody": true,
